# 기본: 모든 텍스트 파일 줄바꿈 자동 통일 (Windows ↔ Mac/Linux 혼용 방지)
* text=auto eol=lf

# 소스코드
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.env*  text eol=lf

# Python
*.py    text eol=lf
*.txt   text eol=lf

# Windows 배치 파일은 CRLF 유지
*.bat   text eol=crlf

# 바이너리 파일 (diff/merge 하지 않음)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.zip   binary
